<Window x:Class="PractWarehouse2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PractWarehouse2"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800" Initialized="Window_Initialized" x:Name="mainWindow" Loaded="mainWindow_Loaded" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="0.5*"/>
            <RowDefinition Height="4*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" Grid.Row="0">
            <Label Content="Поиск:" VerticalAlignment="Center"/>
            <TextBox x:Name="tbSearch" TextChanged="tbSearch_TextChanged" Width="200" Margin="5" VerticalAlignment="Center"/>
        </StackPanel>
        <DataGrid Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" x:Name="dgProducts" >
            <DataGrid.Columns>
                <DataGridTextColumn Header="Код" Binding="{Binding ProductId}" Width="60"/>
                <DataGridTextColumn Header="Название" Binding="{Binding ProductName}" Width="200"/>
                <DataGridTextColumn Header="Категория" Binding="{Binding Category}" Width="150"/>
                <DataGridTextColumn Header="Производитель" Binding="{Binding Manufacturer}" Width="200"/>
            </DataGrid.Columns>
        </DataGrid>
        <StackPanel Orientation="Horizontal" Grid.Row="2">
            <Button x:Name="btnAdd" Content="Добавить" Width="100" Height="35" Margin="5" Click="btnAdd_Click"/>
            <Button x:Name="btnEdit" Content="Редактировать" Width="100" Margin="5" Height="35" Click="btnEdit_Click"/>
            <Button x:Name="btnDelete" Content="Удалить" Width="100" Margin="5"  Height="35" Click="btnDelete_Click"/>
        </StackPanel>
    </Grid>
</Window>
