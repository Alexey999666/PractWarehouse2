<Window x:Class="PractWarehouse2.Authorization"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PractWarehouse2"
        mc:Ignorable="d"
            Title="Авторизация" Height="350" Width="300" WindowStartupLocation="CenterScreen"  ResizeMode="NoResize" >
    <Grid>
        <StackPanel >
            <Label Content="Логин" />
            <TextBox x:Name="tbLogin" />
            <Label  Content="Пароль"/>
            <PasswordBox x:Name="tbPassword" PasswordChar="*"/>
            <Button Content="Войти" Click="btnEnter_Click" Margin="0, 15,0,0"/>
            <Button Content="Отмена" Click="btnClose_Click" Margin="0, 15,0,0"/>
            <Button Content="Войти как гость" Click="BtnEnterHowGuest" Margin="0, 15,0,0"/>
        </StackPanel>
    </Grid>
</Window>
